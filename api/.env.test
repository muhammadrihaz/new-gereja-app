APP_NAME="GPI Yehuda API"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- DATABASE SETUP (MariaDB Test) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gereja_api_test
DB_USERNAME=root
DB_PASSWORD=

# --- SESSION & CACHE ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=array

# --- REDIS SETUP ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- MAIL SETUP (disabled in tests) ---
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=admin@gereja-gpiyehuda.my.id
MAIL_FROM_NAME="GPI Yehuda"

# --- NOTIFICATION SETUP (FCM) ---
FCM_ENABLED=false
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_ENDPOINT=https://fcm.googleapis.com/fcm/send
EMAIL_NOTIFICATIONS_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
